{
  "name": "rondo-api",
  "version": "1.0.0",
  "description": "Backend for Rondo Proyect",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "start": "node  --env-file .env.production src/main.ts",
    "dev": "node --env-file .env.development --watch src/main.ts",
    "test": "vitest --no-file-parallelism",
    "test:unit": "vitest run --config src/test/config/vitest.unit.config.ts",
    "test:integration": "vitest run --config src/test/config/vitest.integration.config.ts --no-file-parallelism",
    "test:e2e": "vitest run --config src/test/config/vitest.e2e.config.ts",
    "coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-personal:Rondo-Team/rondo-api.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@hono/swagger-ui": "^0.4.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "hono": "^4.7.4",
    "hono-openapi": "^0.3.1",
    "inversify": "^7.10.4",
    "mongodb": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.1.4",
    "zod": "^3.24.2",
    "zod-openapi": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.5",
    "@vitest/coverage-v8": "^4.0.10",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.10"
  }
}
